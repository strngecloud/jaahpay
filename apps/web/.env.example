# ============================================
# Core app
# ============================================
# Spend API (NestJS backend)
NEXT_PUBLIC_SPEND_API_URL=http://localhost:3001/api/v1

# Network (42220 = Celo Mainnet, 11142220 = Celo Sepolia testnet)
NEXT_PUBLIC_CHAIN_ID=11142220
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect / Reown project ID — get one free at https://dashboard.reown.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=217502d13f7

# ============================================
# Contracts (Celo Sepolia testnet)
# ============================================
NEXT_PUBLIC_JAHPAY_ROUTER_ADDRESS=0x149dc955D97B60750362Aff6C6673c7444fB019E
NEXT_PUBLIC_FEE_COLLECTOR_ADDRESS=0x4551cDf8741AFa6E1D8d247C700745ff9b2EA0B6
NEXT_PUBLIC_RAMP_AGGREGATOR_ADDRESS=0x3e21dc4d7d43783cfbb82822f6685cd24fcab8fa

NEXT_PUBLIC_MENTO_ENABLED=true

# ============================================
# Agent (ERC-8004) & x402
# ============================================
# Set after first registration via `pnpm deploy:agent`
NEXT_PUBLIC_AGENT_ID=9105

# Thirdweb x402 (playground + premium agent analysis)
# Get keys at https://thirdweb.com/dashboard -> Settings -> API Keys
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=75838d36b75c
THIRDWEB_SECRET_KEY=TnnEGWPocbX6bD8fVkOOzSg

# Server-only: ERC-8004 agent registration & on-chain feedback
AGENT_DEPLOYER_PRIVATE_KEY=0xcefc4fea798f236

# ERC-8004 registries on Celo Mainnet
NEXT_PUBLIC_ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
NEXT_PUBLIC_ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
NEXT_PUBLIC_ERC8004_VALIDATION_REGISTRY=

# ============================================
# ArbBot (pnpm bot:arb) — Mento vs Uniswap V3 USDC/USDT
# ============================================
# Dedicated bot wallet; needs USDC/USDT inventory + a little CELO for gas.
# Falls back to PRIVATE_KEY if unset.
ARB_BOT_PRIVATE_KEY=
ARB_EXECUTE=
ARB_TRADE_SIZE=50
ARB_MIN_TRADE_SIZE=5
ARB_MIN_EDGE_BPS=5
ARB_SLIPPAGE_BPS=10
ARB_POLL_MS=20000
ARB_GAS_USD_PER_LEG=0.01
ARB_COUNT_PLATFORM_FEE_AS_COST=true
ARB_RPC_URL=

# ============================================
# Fee sweep (pnpm bot:sweep)
# ============================================
# Owner key of the FeeCollector (also used by deploy scripts)
PRIVATE_KEY=0xce18aa4d2998f236
EXECUTE=1
SWEEP_TO=

# ============================================
# Optional integrations
# ============================================
# Sentry error tracking — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_APP_ENV=development

# PostHog analytics — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=

# ─── Admin console (/admin) ───
# Comma-separated wallet addresses allowed to sign in to the admin dashboard
ADMIN_WALLET_ADDRESSES=0x3E192d109d1dd323375Ac1Ed040f817918E82d63
# Random secret for signing admin session cookies (e.g. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=d382673da9fbeb38dcf62
# Shared key the admin API routes use to reach the NestJS server's guarded
# admin endpoints — MUST match ADMIN_API_KEY in apps/server/.env
ADMIN_API_KEY=15eb812a8056

# ─── x402 ───
# Wallet that receives x402 payments (defaults to NEXT_PUBLIC_FEE_COLLECTOR_ADDRESS).
# For the Celo Builders hackathon this MUST be the wallet registered on the
# allowlist — facilitator settlements are attributed by payer/payee wallet.
X402_PAYTO_ADDRESS=0x3E192d109d1dd323375Ac1Ed040f817918E82d63
# API key for the Celo facilitator's /settle endpoint — REQUIRED for payments
# to actually settle. Self-serve: `pnpm x402:keygen` (gas-free wallet signature).
X402_FACILITATOR_API_KEY=
# Price charged per paid API call, in USDC atomic units (6 decimals):
# 1000000 = $1.00, 100 = $0.0001. Sets ALL tiers at once. Read server-side, so
# set this in Vercel prod env (not just here) for jahpay.xyz to use it.
# Per-tier overrides also exist: X402_PRICE_MICRO_ATOMIC / _SMALL_ / _MEDIUM_ / _PREMIUM_.
X402_PRICE_ATOMIC=1000000

# ─── x402 consumer agent (pnpm bot:x402) ───
# Payer wallet key (falls back to PRIVATE_KEY); needs a little USDC
X402_AGENT_PRIVATE_KEY=0x276c7844f2c
# API origin to buy from (default https://jahpay.xyz)
X402_TARGET_URL=https://jahpay.xyz
# ms between purchases (default 60000)
X402_AGENT_POLL_MS=5000
# Refuse offers above this many USDC atomic units (default 10000 = $0.01)
X402_MAX_PRICE_ATOMIC=1000000
# "1" = single smoke-test round, then exit
X402_AGENT_ONCE=1
