# Server Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=jahpay_spending
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Blockchain Configuration
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
BASE_RPC_URL=https://sepolia.base.org
CELO_CHAIN_ID=44787
BASE_CHAIN_ID=84532

# Contract Addresses
SPEND_ROUTER_ADDRESS_CELO=0x0000000000000000000000000000000000000000
SPEND_ROUTER_ADDRESS_BASE=0x0000000000000000000000000000000000000000

# Backend Wallet (for completing/refunding spends)
BACKEND_PRIVATE_KEY=

# Bank API - Wema Alat (Ocp-Apim-Subscription-Key auth)
WEMA_API_URL=https://wema-alatdev-apimgt.azure-api.net/funds-transfer-open/api
WEMA_API_KEY=
WEMA_PRIMARY_KEY=
WEMA_SECONDARY_KEY=
WEMA_SALT_KEY=
WEMA_SOURCE_ACCOUNT=
WEMA_CALLBACK_URL=

# Bank API - Providus
PROVIDUS_API_URL=https://api.providusbank.com/api/v1
PROVIDUS_CLIENT_ID=
PROVIDUS_API_KEY=
PROVIDUS_ACCOUNT_NUMBER=
PROVIDUS_BANK_CODE=035
PROVIDUS_ACCOUNT_NAME=

# Bank API - Paystack (Fallback)
PAYSTACK_API_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=

# Exchange Rate Configuration
EXCHANGE_RATE_UPDATE_INTERVAL=60000
BINANCE_API_URL=https://api.binance.com
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Security Configuration
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
SPEND_TIMEOUT_MINUTES=15
DEFAULT_DAILY_LIMIT_USDC=100
DEFAULT_MONTHLY_LIMIT_USDC=1000

# Logging
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# Admin API key — protects admin endpoints. Generate: openssl rand -hex 32
ADMIN_API_KEY=

# CRITICAL: Processor wallet — must be authorized on SpendRouter.
# Store in a secrets manager in production.
PROCESSOR_WALLET_PRIVATE_KEY=

# Redis URL (required for fraud detection)
REDIS_URL=redis://localhost:6379
