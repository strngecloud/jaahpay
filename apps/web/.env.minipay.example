# MiniPay Configuration
# Copy this file to .env.local and update with your values

# Wallet Connect Project ID (for normal website mode)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id

# Contract Addresses - Celo Mainnet
NEXT_PUBLIC_SPEND_ROUTER_ADDRESS=0x...
NEXT_PUBLIC_FEE_COLLECTOR_ADDRESS=0x...

# Contract Addresses - Celo Sepolia (for testing)
NEXT_PUBLIC_SPEND_ROUTER_ADDRESS_ALFAJORES=0x...
NEXT_PUBLIC_FEE_COLLECTOR_ADDRESS_SEPOLIA=0x...

# Provider API Keys (for fiat on/off ramps)
NEXT_PUBLIC_YELLOWCARD_API_KEY=your_yellowcard_api_key
NEXT_PUBLIC_CASHRAMP_API_KEY=your_cashramp_api_key
NEXT_PUBLIC_BITMAMA_API_KEY=your_bitmama_api_key

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# MiniPay Specific Notes:
# - Only stablecoins are supported: USDm, USDC, USDT
# - Only Celo Mainnet (42220) and Celo Sepolia (11142220) are supported
# - Legacy transactions only (no EIP-1559)
# - Fee currency limited to USDm for now
# - Wallet connection is implicit in MiniPay (no connect button needed)
